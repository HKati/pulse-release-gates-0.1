{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pulse.local/schemas/release_evidence_input_manifest_v0.schema.json",
  "title": "PULSE Release Evidence Input Manifest v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "created_utc",
    "manifest_id",
    "manifest_version",
    "run_identity",
    "subject",
    "policy_binding",
    "registry_binding",
    "candidate_evidence",
    "expected_relation_bindings",
    "expected_gate_materialization",
    "fail_closed_requirements",
    "warnings"
  ],
  "properties": {
    "schema_version": {
      "const": "release_evidence_input_manifest_v0"
    },
    "created_utc": {
      "type": "string",
      "minLength": 1
    },
    "manifest_id": {
      "type": "string",
      "minLength": 1
    },
    "manifest_version": {
      "type": "string",
      "minLength": 1
    },
    "run_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_mode",
        "run_key",
        "git_sha"
      ],
      "properties": {
        "run_mode": {
          "const": "prod"
        },
        "run_key": {
          "type": [
            "string",
            "null"
          ]
        },
        "git_sha": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[0-9a-fA-F]{40}$"
        }
      }
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "commit_sha",
        "release_candidate"
      ],
      "properties": {
        "repository": {
          "type": [
            "string",
            "null"
          ]
        },
        "commit_sha": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[0-9a-fA-F]{40}$"
        },
        "release_candidate": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "policy_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_path",
        "policy_sha256",
        "policy_set"
      ],
      "properties": {
        "policy_path": {
          "type": "string",
          "minLength": 1
        },
        "policy_sha256": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[0-9a-fA-F]{64}$"
        },
        "policy_set": {
          "const": "required+release_required"
        }
      }
    },
    "registry_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "registry_path",
        "registry_sha256"
      ],
      "properties": {
        "registry_path": {
          "type": "string",
          "minLength": 1
        },
        "registry_sha256": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[0-9a-fA-F]{64}$"
        }
      }
    },
    "candidate_evidence": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "$ref": "#/$defs/candidate_evidence_entry"
      }
    },
    "expected_relation_bindings": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "$ref": "#/$defs/expected_relation_binding"
      }
    },
    "expected_gate_materialization": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "$ref": "#/$defs/expected_gate_materialization_entry"
      }
    },
    "fail_closed_requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{64}$"
    },
    "candidate_evidence_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "path",
        "expected_sha256",
        "schema_version",
        "subject_binding",
        "provenance_expectations",
        "required_for_gates",
        "verification_required"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "detector_evidence",
            "detector_materialization_report",
            "external_detector_summary",
            "refusal_delta_evidence",
            "provenance_record",
            "policy_reference",
            "registry_reference"
          ]
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "expected_sha256": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[0-9a-fA-F]{64}$"
        },
        "schema_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "subject_binding": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "git_sha",
            "run_key"
          ],
          "properties": {
            "git_sha": {
              "type": [
                "string",
                "null"
              ],
              "pattern": "^[0-9a-fA-F]{40}$"
            },
            "run_key": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        },
        "provenance_expectations": {
          "type": "object"
        },
        "required_for_gates": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "verification_required": {
          "const": true
        }
      }
    },
    "expected_relation_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "binding_type",
        "source_evidence_id",
        "target",
        "required",
        "expected_gate_id",
        "failure_if_missing"
      ],
      "properties": {
        "binding_type": {
          "type": "string",
          "enum": [
            "artifact_to_subject",
            "artifact_to_run",
            "artifact_to_policy",
            "artifact_to_registry",
            "artifact_to_digest",
            "artifact_to_detector",
            "artifact_to_gate",
            "gate_to_policy",
            "gate_to_verifier_decision"
          ]
        },
        "source_evidence_id": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "const": true
        },
        "expected_gate_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "failure_if_missing": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "expected_gate_materialization_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "expected_value",
        "candidate_evidence_ids",
        "relation_binding_ids",
        "policy_relation",
        "materialization_allowed_without_verifier"
      ],
      "properties": {
        "expected_value": {
          "const": true
        },
        "candidate_evidence_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "relation_binding_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "policy_relation": {
          "type": "string",
          "minLength": 1
        },
        "materialization_allowed_without_verifier": {
          "const": false
        }
      }
    }
  }
}
