{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/HKati/pulse-release-gates-0.1/schemas/required_gate_evidence_v0.schema.json",
  "title": "PULSE Required Gate Evidence v0",
  "description": "Current-run recorded candidate evidence for the canonical policy-derived gates.required set. This artifact is an input to the non-stubbed prod candidate-status builder. It is not a direct candidate_evidence input for check_recorded_release_evidence_v0.py, does not materialize release_required gates, and does not create release authority.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "created_utc",
    "run_identity",
    "subject",
    "policy_binding",
    "registry_binding",
    "producer",
    "gates",
    "authority_boundary",
    "warnings"
  ],
  "properties": {
    "schema_version": {
      "const": "required_gate_evidence_v0"
    },
    "created_utc": {
      "type": "string",
      "format": "date-time"
    },
    "run_identity": {
      "$ref": "#/$defs/run_identity"
    },
    "subject": {
      "$ref": "#/$defs/subject"
    },
    "policy_binding": {
      "$ref": "#/$defs/policy_binding"
    },
    "registry_binding": {
      "$ref": "#/$defs/registry_binding"
    },
    "producer": {
      "$ref": "#/$defs/producer"
    },
    "gates": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "$ref": "#/$defs/gate_id"
      },
      "additionalProperties": {
        "$ref": "#/$defs/gate_evidence"
      }
    },
    "authority_boundary": {
      "$ref": "#/$defs/authority_boundary"
    },
    "warnings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "git_sha": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1,
      "pattern": "^.*\\S.*$"
    },
    "gate_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "repo_relative_path": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?![A-Za-z]:[\\\\/])(?!\\.{1,2}(?:/|$))(?!.*\\/\\.{1,2}(?:\\/|$))(?!.*\\\\)(?!.*//)[A-Za-z0-9._/-]+$"
    },
    "nullable_non_empty_string": {
      "anyOf": [
        {
          "$ref": "#/$defs/non_empty_string"
        },
        {
          "type": "null"
        }
      ]
    },
    "run_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "git_sha",
        "run_key",
        "run_mode"
      ],
      "properties": {
        "git_sha": {
          "$ref": "#/$defs/git_sha"
        },
        "run_key": {
          "$ref": "#/$defs/non_empty_string"
        },
        "run_mode": {
          "const": "prod"
        }
      }
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "commit_sha",
        "release_candidate"
      ],
      "properties": {
        "repository": {
          "$ref": "#/$defs/non_empty_string"
        },
        "commit_sha": {
          "$ref": "#/$defs/git_sha"
        },
        "release_candidate": {
          "$ref": "#/$defs/nullable_non_empty_string"
        }
      }
    },
    "policy_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_path",
        "policy_sha256",
        "policy_set"
      ],
      "properties": {
        "policy_path": {
          "const": "pulse_gate_policy_v0.yml"
        },
        "policy_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "policy_set": {
          "const": "required"
        }
      }
    },
    "registry_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "registry_path",
        "registry_sha256"
      ],
      "properties": {
        "registry_path": {
          "const": "pulse_gate_registry_v0.yml"
        },
        "registry_sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "version",
        "trusted",
        "tool_path",
        "tool_sha256"
      ],
      "properties": {
        "id": {
          "const": "pulse_recorded_required_gate_evaluator_v0"
        },
        "version": {
          "$ref": "#/$defs/non_empty_string"
        },
        "trusted": {
          "const": true
        },
        "tool_path": {
          "const": "PULSE_safe_pack_v0/tools/run_recorded_required_gate_evaluations_v0.py"
        },
        "tool_sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "artifact_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256",
        "kind",
        "schema_version"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/repo_relative_path"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "kind": {
          "$ref": "#/$defs/non_empty_string"
        },
        "schema_version": {
          "$ref": "#/$defs/nullable_non_empty_string"
        }
      }
    },
    "gate_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "value",
        "status",
        "evaluation_id",
        "evidence_artifacts",
        "diagnostics"
      ],
      "properties": {
        "value": {
          "type": "boolean"
        },
        "status": {
          "enum": [
            "passed",
            "failed"
          ]
        },
        "evaluation_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "evidence_artifacts": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/artifact_ref"
          }
        },
        "diagnostics": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "value": {
                "const": true
              }
            },
            "required": [
              "value"
            ]
          },
          "then": {
            "properties": {
              "status": {
                "const": "passed"
              },
              "diagnostics": {
                "maxItems": 0
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "value": {
                "const": false
              }
            },
            "required": [
              "value"
            ]
          },
          "then": {
            "properties": {
              "status": {
                "const": "failed"
              },
              "diagnostics": {
                "minItems": 1
              }
            }
          }
        }
      ]
    },
    "authority_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "normative",
        "creates_release_authority",
        "materializes_release_required",
        "replaces_check_gates"
      ],
      "properties": {
        "normative": {
          "const": false
        },
        "creates_release_authority": {
          "const": false
        },
        "materializes_release_required": {
          "const": false
        },
        "replaces_check_gates": {
          "const": false
        }
      }
    }
  },
  "x-pulse-contract": {
    "artifact_role": "required_gate_candidate_evidence",
    "direct_recorded_evidence_candidate": false,
    "next_step": "build_release_grade_candidate_status_v0",
    "required_cross_document_checks": [
      "The gates object keys must exactly equal the canonical pulse_gate_policy_v0.yml gates.required set.",
      "Every gates key must exist in pulse_gate_registry_v0.yml.",
      "subject.commit_sha must equal run_identity.git_sha.",
      "producer.tool_path must exist as a checked-in regular file and producer.tool_sha256 must match it.",
      "policy_binding.policy_sha256 must match the canonical policy file.",
      "registry_binding.registry_sha256 must match the canonical registry file.",
      "Every evidence_artifacts path must resolve to a regular file inside the repository.",
      "This artifact must not be supplied directly to check_recorded_release_evidence_v0.py.",
      "A later recorded-release candidate envelope must provide subject_binding, provenance, raw_evidence_binding, required_for_gates, and the required+release_required policy context."
    ]
  }
}
