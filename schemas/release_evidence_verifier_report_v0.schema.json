{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pulse.local/schemas/release_evidence_verifier_report_v0.schema.json",
  "title": "PULSE Release Evidence Verifier Report v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "created_utc",
    "verifier_id",
    "verifier_version",
    "verifier_decision",
    "run_identity",
    "subject",
    "policy_binding",
    "registry_binding",
    "evidence_inputs",
    "verified_artifacts",
    "relation_bindings",
    "gate_materialization",
    "failed_checks",
    "warnings"
  ],
  "properties": {
    "schema_version": {
      "const": "release_evidence_verifier_report_v0"
    },
    "created_utc": {
      "type": "string",
      "minLength": 1
    },
    "verifier_id": {
      "type": "string",
      "minLength": 1
    },
    "verifier_version": {
      "type": "string",
      "minLength": 1
    },
    "verifier_decision": {
      "type": "string",
      "enum": [
        "VERIFIED",
        "FAILED"
      ]
    },
    "run_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_mode",
        "run_key",
        "git_sha"
      ],
      "properties": {
        "run_mode": {
          "const": "prod"
        },
        "run_key": {
          "type": [
            "string",
            "null"
          ]
        },
        "git_sha": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[0-9a-fA-F]{40}$"
        }
      }
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "commit_sha",
        "release_candidate"
      ],
      "properties": {
        "repository": {
          "type": [
            "string",
            "null"
          ]
        },
        "commit_sha": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[0-9a-fA-F]{40}$"
        },
        "release_candidate": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "policy_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_path",
        "policy_sha256",
        "policy_set"
      ],
      "properties": {
        "policy_path": {
          "type": "string",
          "minLength": 1
        },
        "policy_sha256": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[0-9a-fA-F]{64}$"
        },
        "policy_set": {
          "const": "required+release_required"
        }
      }
    },
    "registry_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "registry_path",
        "registry_sha256"
      ],
      "properties": {
        "registry_path": {
          "type": "string",
          "minLength": 1
        },
        "registry_sha256": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[0-9a-fA-F]{64}$"
        }
      }
    },
    "evidence_inputs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidence_input"
      }
    },
    "verified_artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/verified_artifact"
      }
    },
    "relation_bindings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/relation_binding"
      }
    },
    "gate_materialization": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "$ref": "#/$defs/gate_materialization_entry"
      }
    },
    "failed_checks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{64}$"
    },
    "candidate_validation_diagnostic_status": {
      "type": "string",
      "enum": [
        "not_run",
        "unavailable",
        "failed"
      ]
    },
    "candidate_validation_diagnostic_error": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "message"
      ],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "instance_path": {
          "type": "string"
        },
        "schema_path": {
          "type": "string"
        }
      }
    },
    "duplicate_key_validation_draft": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "$ref": "#/$defs/candidate_validation_diagnostic_status"
        },
        "errors": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/candidate_validation_diagnostic_error"
          }
        }
      }
    },
    "candidate_schema_validation_draft": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "$ref": "#/$defs/candidate_validation_diagnostic_status"
        },
        "schema_path": {
          "type": [
            "string",
            "null"
          ]
        },
        "schema_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "errors": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/candidate_validation_diagnostic_error"
          }
        },
        "duplicate_key_validation": {
          "$ref": "#/$defs/duplicate_key_validation_draft"
        }
      }
    },
    "evidence_input": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "path",
        "sha256",
        "schema_version",
        "subject_binding",
        "provenance"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "detector_evidence",
            "detector_materialization_report",
            "external_detector_summary",
            "refusal_delta_evidence",
            "provenance_record",
            "policy_reference",
            "registry_reference"
          ]
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "schema_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "subject_binding": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "git_sha",
            "run_key"
          ],
          "properties": {
            "git_sha": {
              "type": [
                "string",
                "null"
              ],
              "pattern": "^[0-9a-fA-F]{40}$"
            },
            "run_key": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        },
        "provenance": {
          "type": "object",
          "properties": {
            "candidate_schema_validation": {
              "$ref": "#/$defs/candidate_schema_validation_draft"
            }
          },
          "additionalProperties": true
        }
      }
    },
    "verified_artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256",
        "schema_version",
        "verified"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "schema_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "verified": {
          "const": true
        }
      }
    },
    "relation_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "relation_id",
        "binding_type",
        "source",
        "target",
        "verified",
        "evidence"
      ],
      "properties": {
        "relation_id": {
          "type": "string",
          "minLength": 1
        },
        "binding_type": {
          "type": "string",
          "enum": [
            "artifact_to_subject",
            "artifact_to_run",
            "artifact_to_policy",
            "artifact_to_registry",
            "artifact_to_digest",
            "artifact_to_detector",
            "artifact_to_gate",
            "gate_to_policy",
            "gate_to_verifier_decision"
          ]
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "verified": {
          "type": "boolean"
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/verified_artifact"
          }
        },
        "failure_reason": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "verified_relation_binding": {
      "allOf": [
        {
          "$ref": "#/$defs/relation_binding"
        },
        {
          "type": "object",
          "properties": {
            "verified": {
              "const": true
            },
            "evidence": {
              "minItems": 1
            },
            "failure_reason": {
              "type": "null"
            }
          }
        }
      ]
    },
    "gate_materialization_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "value",
        "source",
        "verified",
        "evidence_artifacts",
        "relation_bindings",
        "policy_relation"
      ],
      "properties": {
        "value": {
          "type": "boolean"
        },
        "source": {
          "const": "release_evidence_verifier_report_v0"
        },
        "verified": {
          "const": true
        },
        "evidence_artifacts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/verified_artifact"
          }
        },
        "relation_bindings": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "policy_relation": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "verifier_decision": {
            "const": "FAILED"
          }
        },
        "required": [
          "verifier_decision"
        ]
      },
      "then": {
        "properties": {
          "failed_checks": {
            "minItems": 1
          },
          "gate_materialization": {
            "maxProperties": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "verifier_decision": {
            "const": "VERIFIED"
          }
        },
        "required": [
          "verifier_decision"
        ]
      },
      "then": {
        "properties": {
          "failed_checks": {
            "maxItems": 0
          },
          "gate_materialization": {
            "minProperties": 1
          },
          "verified_artifacts": {
            "minItems": 1
          },
          "relation_bindings": {
            "minItems": 1,
            "items": {
              "$ref": "#/$defs/verified_relation_binding"
            }
          }
        }
      }
    }
  ]
}
