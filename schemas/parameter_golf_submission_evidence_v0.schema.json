{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hkati.github.io/pulse-release-gates-0.1/schemas/parameter_golf_submission_evidence_v0.schema.json",
  "title": "Parameter Golf submission evidence v0",
  "description": "Shadow-only evidence contract for OpenAI Parameter Golf submissions.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "submission_type",
    "artifact",
    "evaluation"
  ],
  "properties": {
    "schema_version": {
      "const": "0.1"
    },
    "submission_type": {
      "type": "string",
      "enum": [
        "record",
        "non_record",
        "non_record_unlimited_compute",
        "baseline",
        "other"
      ]
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code_bytes",
        "model_bytes_int8_zlib",
        "total_bytes_int8_zlib"
      ],
      "properties": {
        "code_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "model_bytes_raw": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "model_bytes_int8_zlib": {
          "type": "integer",
          "minimum": 0
        },
        "total_bytes_int8_zlib": {
          "type": "integer",
          "minimum": 0
        },
        "artifact_limit_bytes": {
          "type": "integer",
          "minimum": 1,
          "default": 16000000
        },
        "tokenizer_counted": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "tokenizer_bytes_if_counted": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        }
      }
    },
    "train": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "train_wallclock_s": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "max_wallclock_s": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "world_size": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "gpu_type": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "seed": {
          "type": [
            "integer",
            "null"
          ]
        }
      }
    },
    "evaluation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "val_bpb"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "standard",
            "sliding_window",
            "ttt_lora",
            "other"
          ]
        },
        "seq_len": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "stride": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "val_loss": {
          "type": [
            "number",
            "null"
          ]
        },
        "val_bpb": {
          "type": "number"
        },
        "eval_wallclock_s": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "roundtrip_val_loss": {
          "type": [
            "number",
            "null"
          ]
        },
        "roundtrip_val_bpb": {
          "type": [
            "number",
            "null"
          ]
        }
      }
    },
    "stats": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "run_logs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "n_runs": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "p_value": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "comparison_target": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "claim_exemption_reason": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source_repo": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "source_commit": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "record_path": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "generated_by": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "notes": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}
