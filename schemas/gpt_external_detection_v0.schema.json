{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/gpt_external_detection_v0.schema.json",
  "title": "GPT External Detection Overlay v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "created_at",
    "input_file",
    "summary",
    "records"
  ],
  "properties": {
    "version": {
      "const": "gpt_external_detection_v0"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "input_file": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_records",
        "num_external_gpt",
        "num_internal",
        "num_unknown",
        "vendors",
        "models"
      ],
      "properties": {
        "total_records": {
          "type": "integer",
          "minimum": 0
        },
        "num_external_gpt": {
          "type": "integer",
          "minimum": 0
        },
        "num_internal": {
          "type": "integer",
          "minimum": 0
        },
        "num_unknown": {
          "type": "integer",
          "minimum": 0
        },
        "vendors": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "models": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "idx",
          "id",
          "is_external_gpt",
          "is_internal",
          "vendor",
          "model",
          "reason"
        ],
        "properties": {
          "idx": {
            "type": "integer",
            "minimum": 1
          },
          "id": {
            "type": [
              "string",
              "null"
            ]
          },
          "is_external_gpt": {
            "type": "boolean"
          },
          "is_internal": {
            "type": "boolean"
          },
          "vendor": {
            "type": [
              "string",
              "null"
            ]
          },
          "model": {
            "type": [
              "string",
              "null"
            ]
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
