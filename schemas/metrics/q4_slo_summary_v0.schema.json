{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hkati.github.io/pulse-release-gates-0.1/schemas/metrics/q4_slo_summary_v0.schema.json",
  "title": "Q4 SLO Reference Summary Contract (v0)",
  "description": "Schema for deterministic, artifact-first Q4 SLO reference summaries used for Core/reference materialization in PULSE.",
  "type": "object",
  "required": [
    "spec_id",
    "spec_version",
    "run_id",
    "created_utc",
    "n_requests",
    "min_requests",
    "insufficient_evidence",
    "latency_p95_ms",
    "latency_budget_ms",
    "latency_ok",
    "cost_p95_usd",
    "cost_budget_usd",
    "cost_ok",
    "pass",
    "method",
    "provenance"
  ],
  "properties": {
    "spec_id": {
      "type": "string",
      "const": "q4_slo_v0"
    },
    "spec_version": {
      "type": "string",
      "const": "0.1.0"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "created_utc": {
      "type": "string",
      "minLength": 1
    },
    "n_requests": {
      "type": "integer",
      "minimum": 0
    },
    "min_requests": {
      "type": "integer",
      "minimum": 0
    },
    "insufficient_evidence": {
      "type": "boolean"
    },
    "latency_p95_ms": {
      "type": "number",
      "minimum": 0
    },
    "latency_budget_ms": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "latency_ok": {
      "type": "boolean"
    },
    "cost_p95_usd": {
      "type": "number",
      "minimum": 0
    },
    "cost_budget_usd": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "cost_ok": {
      "type": "boolean"
    },
    "pass": {
      "type": "boolean"
    },
    "pass_basis": {
      "type": "string"
    },
    "primary_metric_id": {
      "type": "string"
    },
    "budget_ratios": {
      "type": "object",
      "properties": {
        "latency_p95_ratio": {
          "type": ["number", "null"],
          "minimum": 0
        },
        "cost_p95_ratio": {
          "type": ["number", "null"],
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "method": {
      "type": "object",
      "required": ["kind", "deterministic"],
      "properties": {
        "kind": {
          "type": "string",
          "const": "reference"
        },
        "deterministic": {
          "type": "boolean",
          "const": true
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "provenance": {
      "type": "object",
      "required": ["input_manifest", "stats_json", "tool"],
      "properties": {
        "input_manifest": {
          "type": "string",
          "minLength": 1
        },
        "stats_json": {
          "type": "string",
          "minLength": 1
        },
        "tool": {
          "type": "string",
          "minLength": 1
        },
        "tool_version": {
          "type": "string",
          "minLength": 1
        },
        "git_sha": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "notes": {
      "type": "string"
    },
    "decision_rule": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
