{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/g_epf_overlay_v0.schema.json",
  "title": "G-EPF Overlay v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "created_at",
    "g_field",
    "status_baseline",
    "status_epf",
    "epf_paradox_summary",
    "diagnostics"
  ],
  "properties": {
    "version": {
      "const": "g_epf_overlay_v0"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "g_field": {
      "type": "object",
      "additionalProperties": true
    },
    "status_baseline": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "status_epf": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "epf_paradox_summary": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "diagnostics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "paradox_gate_ids",
        "g_points_on_paradox_gates"
      ],
      "properties": {
        "paradox_gate_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "g_points_on_paradox_gates": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": [
              "id",
              "g_value"
            ],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "g_value": {
                "type": "number"
              }
            }
          }
        }
      }
    }
  }
}
