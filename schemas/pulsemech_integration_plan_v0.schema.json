{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/HKati/pulse-release-gates-0.1/schemas/pulsemech_integration_plan_v0.schema.json",
  "title": "PULSEmech integration plan v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "plan_type",
    "tool",
    "request_id",
    "source",
    "target",
    "selection",
    "operations",
    "conflicts",
    "unresolved",
    "summary",
    "apply_eligible",
    "authority_boundary"
  ],
  "properties": {
    "schema_version": {
      "const": "pulsemech_integration_plan_v0"
    },
    "plan_type": {
      "const": "pulsemech_integration_plan"
    },
    "tool": {
      "const": "plan_pulsemech_integration_v0"
    },
    "request_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "revision",
        "component_manifest_path",
        "component_manifest_sha256",
        "policy_path",
        "policy_sha256"
      ],
      "properties": {
        "repository": {
          "$ref": "#/$defs/non_empty_string"
        },
        "revision": {
          "$ref": "#/$defs/sha40"
        },
        "component_manifest_path": {
          "$ref": "#/$defs/non_empty_string"
        },
        "component_manifest_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "policy_path": {
          "$ref": "#/$defs/non_empty_string"
        },
        "policy_sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository_id",
        "default_branch",
        "declared_ci_provider",
        "detected_ci_providers"
      ],
      "properties": {
        "repository_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "default_branch": {
          "$ref": "#/$defs/non_empty_string"
        },
        "declared_ci_provider": {
          "$ref": "#/$defs/non_empty_string"
        },
        "detected_ci_providers": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        }
      }
    },
    "selection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "component_sets",
        "resolved_components",
        "declared_gate_sets"
      ],
      "properties": {
        "component_sets": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "resolved_components": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "declared_gate_sets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/gate_set"
          }
        }
      }
    },
    "operations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/operation"
      }
    },
    "conflicts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      }
    },
    "unresolved": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "files_total",
        "create",
        "preserve",
        "conflict",
        "source_missing",
        "unresolved"
      ],
      "properties": {
        "files_total": {
          "type": "integer",
          "minimum": 0
        },
        "create": {
          "type": "integer",
          "minimum": 0
        },
        "preserve": {
          "type": "integer",
          "minimum": 0
        },
        "conflict": {
          "type": "integer",
          "minimum": 0
        },
        "source_missing": {
          "type": "integer",
          "minimum": 0
        },
        "unresolved": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "apply_eligible": {
      "type": "boolean"
    },
    "authority_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "write_mode",
        "writes_target_repository",
        "changes_release_authority",
        "changes_gate_policy",
        "changes_gate_semantics",
        "creates_release_decision"
      ],
      "properties": {
        "write_mode": {
          "const": "plan_only"
        },
        "writes_target_repository": {
          "const": false
        },
        "changes_release_authority": {
          "const": false
        },
        "changes_gate_policy": {
          "const": false
        },
        "changes_gate_semantics": {
          "const": false
        },
        "creates_release_decision": {
          "const": false
        }
      }
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "sha40": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "gate_set": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "gate_count",
        "gates",
        "sha256"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "gate_count": {
          "type": "integer",
          "minimum": 1
        },
        "gates": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "operation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "component_id",
        "source_path",
        "target_path",
        "source_sha256",
        "source_size_bytes",
        "target_state",
        "action",
        "reason"
      ],
      "properties": {
        "component_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "source_path": {
          "$ref": "#/$defs/non_empty_string"
        },
        "target_path": {
          "$ref": "#/$defs/non_empty_string"
        },
        "source_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "source_size_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "target_state": {
          "enum": [
            "missing",
            "identical",
            "different",
            "symlink",
            "directory",
            "non_regular",
            "path_component_symlink",
            "path_component_non_directory"
          ]
        },
        "action": {
          "enum": [
            "create",
            "preserve",
            "conflict"
          ]
        },
        "reason": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "path",
        "message"
      ],
      "properties": {
        "kind": {
          "$ref": "#/$defs/non_empty_string"
        },
        "path": {
          "$ref": "#/$defs/non_empty_string"
        },
        "message": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    }
  }
}
