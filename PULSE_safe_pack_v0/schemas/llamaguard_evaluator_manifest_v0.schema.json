{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hkati.github.io/pulse-release-gates-0.1/schemas/llamaguard_evaluator_manifest_v0.schema.json",
  "title": "PULSE LlamaGuard Current-Run Evaluator Manifest v0",
  "description": "Manifest for the current-run LlamaGuard raw-evidence producer. This schema validates evaluator and evidence bindings only; it does not create release authority.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "producer",
    "run",
    "model",
    "runtime",
    "dataset",
    "output",
    "authority_boundary"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "llamaguard_current_run_evaluator_v0"
    },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tool",
        "version"
      ],
      "properties": {
        "tool": {
          "type": "string",
          "const": "run_llamaguard_current_evidence_v0.py"
        },
        "version": {
          "type": "string",
          "const": "0.1.0"
        }
      }
    },
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "git_sha",
        "run_key",
        "workflow_ref",
        "release_candidate",
        "created_utc"
      ],
      "properties": {
        "repository": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
        },
        "git_sha": {
          "type": "string",
          "pattern": "^[0-9a-fA-F]{40}$"
        },
        "run_key": {
          "type": "string",
          "pattern": "^GITHUB_RUN_ID=[1-9][0-9]*\\|GITHUB_RUN_ATTEMPT=[1-9][0-9]*\\|GITHUB_WORKFLOW=.+$"
        },
        "workflow_ref": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+/\\.github/workflows/pulse_ci\\.yml@.+$"
        },
        "release_candidate": {
          "type": "string",
          "minLength": 1
        },
        "created_utc": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "requested_revision",
        "resolved_revision",
        "dtype"
      ],
      "properties": {
        "id": {
          "type": "string",
          "const": "meta-llama/Llama-Guard-3-1B"
        },
        "requested_revision": {
          "type": "string",
          "minLength": 1
        },
        "resolved_revision": {
          "type": "string",
          "pattern": "^[0-9a-fA-F]{40}$"
        },
        "dtype": {
          "type": "string",
          "enum": [
            "bfloat16",
            "float32"
          ]
        }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "python",
        "torch",
        "transformers",
        "huggingface_hub",
        "safetensors",
        "device",
        "torch_threads",
        "deterministic_generation"
      ],
      "properties": {
        "python": {
          "type": "string",
          "minLength": 1
        },
        "torch": {
          "type": "string",
          "minLength": 1
        },
        "transformers": {
          "type": "string",
          "minLength": 1
        },
        "huggingface_hub": {
          "type": "string",
          "minLength": 1
        },
        "safetensors": {
          "type": "string",
          "minLength": 1
        },
        "device": {
          "type": "string",
          "const": "cpu"
        },
        "torch_threads": {
          "type": "integer",
          "minimum": 1,
          "maximum": 16
        },
        "deterministic_generation": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "manual_seed",
            "do_sample",
            "num_beams",
            "max_new_tokens"
          ],
          "properties": {
            "manual_seed": {
              "type": "integer",
              "const": 0
            },
            "do_sample": {
              "type": "boolean",
              "const": false
            },
            "num_beams": {
              "type": "integer",
              "const": 1
            },
            "max_new_tokens": {
              "type": "integer",
              "minimum": 1,
              "maximum": 64
            }
          }
        }
      }
    },
    "dataset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256",
        "case_count"
      ],
      "properties": {
        "path": {
          "type": "string",
          "const": "PULSE_safe_pack_v0/examples/llamaguard_current_run_cases_v0.jsonl"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-fA-F]{64}$"
        },
        "case_count": {
          "type": "integer",
          "minimum": 1,
          "maximum": 32
        }
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "raw_evidence_path",
        "raw_evidence_sha256",
        "record_count",
        "safe_count",
        "unsafe_count"
      ],
      "properties": {
        "raw_evidence_path": {
          "type": "string",
          "const": "PULSE_safe_pack_v0/artifacts/external/llamaguard_raw.jsonl"
        },
        "raw_evidence_sha256": {
          "type": "string",
          "pattern": "^[0-9a-fA-F]{64}$"
        },
        "record_count": {
          "type": "integer",
          "minimum": 1,
          "maximum": 32
        },
        "safe_count": {
          "type": "integer",
          "minimum": 0,
          "maximum": 32
        },
        "unsafe_count": {
          "type": "integer",
          "minimum": 0,
          "maximum": 32
        }
      }
    },
    "authority_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "creates_release_authority",
        "materializes_status",
        "materializes_release_required",
        "creates_attestation",
        "replaces_check_gates"
      ],
      "properties": {
        "creates_release_authority": {
          "type": "boolean",
          "const": false
        },
        "materializes_status": {
          "type": "boolean",
          "const": false
        },
        "materializes_release_required": {
          "type": "boolean",
          "const": false
        },
        "creates_attestation": {
          "type": "boolean",
          "const": false
        },
        "replaces_check_gates": {
          "type": "boolean",
          "const": false
        }
      }
    }
  }
}
